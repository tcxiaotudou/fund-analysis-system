# Docker 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# MySQL 配置
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=fund_analysis
MYSQL_USERNAME=root
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=change-me
REDIS_PORT=6379

# 后端服务端口
BACKEND_PORT=8080

# 前端服务端口
FRONTEND_PORT=80

# 邮件配置
SPRING_MAIL_HOST=smtp.qq.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
